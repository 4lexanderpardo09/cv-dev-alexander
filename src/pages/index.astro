---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import Profile from '../components/Profile.astro';
import Experience from '../components/Experience.astro';
import Skills from '../components/Skills.astro';
import Education from '../components/Education.astro';
import Languages from '../components/Languages.astro';
import SoftSkills from '../components/SoftSkills.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Hero />
  <Profile />
  <Experience />

  <!-- Bento Grid -->
  <div class="bento bento-2">
    <Skills />
    <div>
      <div class="bento bento-3" style="margin-bottom:6px;">
        <Education />
        <Languages />
        <SoftSkills />
      </div>

      <div class="status-bar reveal">
        <span><span class="sb-dot"></span> Disponible para oportunidades</span>
        <span><span class="sb-key">Popayán, Colombia</span> · Remoto / Presencial</span>
      </div>
    </div>
  </div>

  <Footer />
</Layout>
