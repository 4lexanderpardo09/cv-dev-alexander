---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import Profile from '../components/Profile.astro';
import Experience from '../components/Experience.astro';
import Skills from '../components/Skills.astro';
import Education from '../components/Education.astro';
import Languages from '../components/Languages.astro';
import SoftSkills from '../components/SoftSkills.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Hero />
  <Profile />
  <Experience />

  <div class="grid-2">
    <Skills />
    <div style="display:flex; flex-direction:column; gap:4px;">
      <Education />
      <Languages />
      <SoftSkills />
    </div>
  </div>

  <div class="status-bar reveal">
    <div class="sb-left">
      <span><span class="sb-indicator"></span> Disponible para oportunidades</span>
    </div>
    <div class="sb-right">
      <span>Ubicación: <span class="sb-key">Popayán, Colombia</span></span>
      <span>Método: <span class="sb-key">Remoto / Presencial</span></span>
    </div>
  </div>

  <Footer />
</Layout>
