---
// Layout — diseño limpio tipo mxb.dev
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Alexander Pardo — Desarrollador de Software</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>
  <style is:global>
    :root {
      --bg:          #090d0e;
      --surface:     rgba(14, 20, 24, 0.35);
      --surface-h:   rgba(20, 30, 34, 0.5);
      --border:      rgba(30, 42, 46, 0.3);
      --border-h:    rgba(0, 229, 160, 0.2);
      --green:       #00e5a0;
      --blue:        #0099ff;
      --purple:      #a855f7;
      --muted:       #4a6270;
      --text:        #c8d8de;
      --bright:      #eaf4f8;
      --mono:        'JetBrains Mono', monospace;
      --sans:        'Syne', sans-serif;
      --grad:        linear-gradient(135deg, #00e5a0 0%, #0099ff 50%, #a855f7 100%);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      font-size: 14px;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ─── NOISE ─── */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.15;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    }

    /* ─── WRAPPER ─── */
    .wrapper {
      position: relative;
      z-index: 1;
      max-width: 820px;
      margin: 0 auto;
      padding: 48px 28px 80px;
    }

    /* ─── SCROLL REVEAL ─── */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-d1 { transition-delay: 0.1s; }
    .reveal-d2 { transition-delay: 0.2s; }
    .reveal-d3 { transition-delay: 0.3s; }

    /* ─── GRADIENT TEXT ─── */
    .gradient-text {
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ─── SECTION LABEL ─── */
    .section-label {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--border), transparent);
    }

    /* ─── CARD ─── */
    .card {
      background: var(--surface);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 32px;
      transition: border-color 0.3s, background 0.3s;
    }
    .card:hover {
      border-color: var(--border-h);
      background: var(--surface-h);
    }

    .card-sm {
      background: var(--surface);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 24px;
      transition: border-color 0.3s;
    }
    .card-sm:hover { border-color: var(--border-h); }

    /* ─── HERO ─── */
    .hero {
      margin-bottom: 20px;
    }

    .hero-name {
      font-family: var(--sans);
      font-size: clamp(36px, 7vw, 58px);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -1.5px;
      color: var(--bright);
      margin-bottom: 8px;
    }

    .hero-sub {
      font-size: 15px;
      color: var(--muted);
      margin-bottom: 20px;
      line-height: 1.6;
    }
    .hero-sub strong {
      font-weight: 500;
      color: var(--green);
    }

    .hero-contact {
      display: flex;
      flex-wrap: wrap;
      gap: 12px 24px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
    }
    .hero-contact a {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text);
      text-decoration: none;
      transition: color 0.2s;
    }
    .hero-contact a:hover { color: var(--green); }
    .hero-contact svg { opacity: 0.4; flex-shrink: 0; }
    .hero-contact a:hover svg { opacity: 1; }

    /* ─── ABOUT ─── */
    .about { margin-bottom: 20px; }
    .about p {
      font-size: 13.5px;
      line-height: 1.9;
      color: var(--text);
    }
    .about strong {
      font-weight: 500;
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ─── BENTO GRID ─── */
    .bento {
      display: grid;
      gap: 6px;
      margin-bottom: 6px;
    }
    .bento-2 { grid-template-columns: 1.3fr 1fr; }
    .bento-3 { grid-template-columns: 1fr 1fr 1fr; }
    @media (max-width: 768px) {
      .bento-2, .bento-3 { grid-template-columns: 1fr; }
    }

    /* ─── EXPERIENCE ─── */
    .exp-list { display: flex; flex-direction: column; gap: 0; }

    .exp-item {
      position: relative;
      padding: 20px 0 20px 28px;
    }
    .exp-item:first-child { padding-top: 0; }
    .exp-item:last-child { padding-bottom: 0; }

    .exp-dot {
      position: absolute;
      left: 0; top: 26px;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--bg);
      border: 2px solid var(--green);
      box-shadow: 0 0 0 3px rgba(0, 229, 160, 0.06);
      z-index: 1;
    }
    .exp-item:first-child .exp-dot { top: 5px; }

    .exp-line {
      position: absolute;
      left: 4px; top: 12px;
      width: 1px;
      bottom: 0;
      background: var(--border);
    }
    .exp-item:last-child .exp-line { display: none; }

    .exp-line-fill {
      position: absolute;
      left: 4px; top: 12px;
      width: 1px;
      bottom: 0;
      background: linear-gradient(var(--green), var(--blue));
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 1s ease;
    }
    .exp-item:last-child .exp-line-fill { display: none; }
    .exp-item.draw .exp-line-fill { transform: scaleY(1); }

    .exp-role {
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 600;
      color: var(--bright);
      margin-bottom: 2px;
    }

    .exp-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 11px;
      margin-bottom: 8px;
    }
    .exp-company {
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }
    .exp-date { color: var(--muted); }

    .exp-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .exp-bullets li {
      font-size: 12.5px;
      color: var(--text);
      padding-left: 16px;
      position: relative;
      line-height: 1.7;
    }
    .exp-bullets li::before {
      content: '–';
      position: absolute;
      left: 0;
      color: var(--muted);
    }

    /* ─── SKILLS ─── */
    .skill-group { margin-bottom: 16px; }
    .skill-group:last-child { margin-bottom: 0; }

    .skill-cat {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .skill-tags { display: flex; flex-wrap: wrap; gap: 5px; }

    .tag {
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 4px;
      border: 1px solid var(--border);
      color: var(--text);
      transition: all 0.2s;
    }
    .tag:hover {
      border-color: var(--green);
      color: var(--green);
    }

    .tag-green {
      border-color: rgba(0, 229, 160, 0.2);
      color: var(--green);
    }
    .tag-blue {
      border-color: rgba(0, 153, 255, 0.2);
      color: var(--blue);
    }
    .tag-purple {
      border-color: rgba(168, 85, 247, 0.2);
      color: var(--purple);
    }

    .tag-stagger {
      opacity: 0;
      transform: translateY(4px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .skill-tags.visible .tag-stagger {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── EDUCATION ─── */
    .edu-item { padding-left: 22px; position: relative; }
    .edu-item::before {
      content: '';
      position: absolute;
      left: 0; top: 5px;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--bg);
      border: 2px solid var(--blue);
    }

    .edu-degree {
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 600;
      color: var(--bright);
      margin-bottom: 2px;
    }
    .edu-school {
      font-size: 11px;
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }
    .edu-date {
      font-size: 11px;
      color: var(--muted);
      margin-top: 2px;
    }

    /* ─── LANGUAGES ─── */
    .lang-list { display: flex; flex-direction: column; gap: 14px; }

    .lang-name { font-size: 12.5px; color: var(--bright); margin-bottom: 2px; }
    .lang-level { font-size: 11px; color: var(--muted); }

    .lang-bar {
      height: 3px;
      background: var(--border);
      border-radius: 2px;
      margin-top: 6px;
      overflow: hidden;
    }
    .lang-fill {
      height: 100%;
      width: 0;
      border-radius: 2px;
      background: linear-gradient(90deg, var(--green), var(--blue));
      transition: width 1s ease;
    }

    /* ─── SOFT SKILLS ─── */
    .soft-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }
    .soft-item {
      font-size: 11px;
      padding: 5px 12px;
      border-radius: 4px;
      border: 1px solid var(--border);
      color: var(--text);
      transition: all 0.2s;
    }
    .soft-item:hover {
      border-color: var(--purple);
      color: var(--purple);
    }

    /* ─── STATUS BAR ─── */
    .status-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 20px;
      border-radius: 8px;
      background: var(--surface);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border);
      font-size: 11px;
      color: var(--muted);
    }
    .sb-dot {
      display: inline-block;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--green);
      margin-right: 6px;
    }
    .sb-key { color: var(--text); }
    @media (max-width: 600px) {
      .status-bar { flex-direction: column; gap: 4px; text-align: center; }
    }

    /* ─── FOOTER ─── */
    .footer {
      text-align: center;
      margin-top: 32px;
      font-size: 11px;
      color: var(--muted);
    }
    .footer .gradient-text { font-weight: 600; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 600px) {
      .card { padding: 24px 20px; }
      .card-sm { padding: 20px; }
      .wrapper { padding: 28px 16px 60px; }
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <slot />
  </div>

  <script>
    // @ts-nocheck
    // ─── SCROLL REVEAL ───
    (function() {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            const exp = e.target.closest('.exp-item');
            if (exp) exp.classList.add('draw');
            const lf = e.target.querySelector('.lang-fill');
            if (lf) { const w = lf.getAttribute('data-width'); if (w) setTimeout(() => { lf.style.width = w; }, 200); }
            const st = e.target.querySelector('.skill-tags');
            if (st) st.classList.add('visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
    })();
  </script>
</body>
</html>
