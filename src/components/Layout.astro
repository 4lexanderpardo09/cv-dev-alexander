---
// Layout — shell HTML + CSS global + efectos visuales
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Alexander Pardo — Desarrollador de Software</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet"/>

  <style is:global>
    /* ═══════════════════════════════════════════
       CSS GLOBAL — Variables, Reset, Layout
       ═══════════════════════════════════════════ */

    :root {
      --bg:       #080c0d;
      --surface:  rgba(17, 22, 24, 0.55);
      --surface-hover: rgba(20, 28, 30, 0.7);
      --border:   #1e2a2e;
      --border-glow: rgba(0, 229, 160, 0.2);
      --accent:   #00e5a0;
      --accent2:  #0099ff;
      --accent-gradient: linear-gradient(135deg, #00e5a0, #0099ff);
      --muted:    #4a6270;
      --text:     #c8d8de;
      --bright:   #eaf4f8;
      --mono:     'JetBrains Mono', monospace;
      --sans:     'Syne', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      font-size: 14px;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ─── NOISE OVERLAY ─── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1;
      opacity: 0.5;
    }

    /* ─── GRID LINES ─── */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(30, 42, 46, 0.4) 1px, transparent 1px),
        linear-gradient(90deg, rgba(30, 42, 46, 0.4) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 1;
      opacity: 0.4;
    }

    /* ─── SPOTLIGHT ─── */
    #spotlight {
      position: fixed;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0, 229, 160, 0.07) 0%, rgba(0, 153, 255, 0.03) 40%, transparent 70%);
      pointer-events: none;
      z-index: 1;
      transform: translate(-50%, -50%);
      transition: left 0.08s linear, top 0.08s linear;
      will-change: left, top;
    }

    /* ─── PARTICLES ─── */
    #particles {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      overflow: hidden;
    }
    .particle {
      position: absolute;
      width: 2px;
      height: 2px;
      background: var(--accent);
      border-radius: 50%;
      opacity: 0;
      animation: floatParticle linear infinite;
    }

    @keyframes floatParticle {
      0%   { transform: translateY(100vh) scale(0); opacity: 0; }
      10%  { opacity: 0.2; }
      90%  { opacity: 0.1; }
      100% { transform: translateY(-10vh) scale(1); opacity: 0; }
    }

    /* ─── LAYOUT ─── */
    .wrapper {
      position: relative;
      z-index: 2;
      max-width: 900px;
      margin: 0 auto;
      padding: 60px 32px 80px;
    }

    /* ─── SCROLL REVEAL ─── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }

    /* ─── GRADIENT TEXT ─── */
    .gradient-text {
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ─── WINDOW DOTS ─── */
    .window-dots {
      display: flex;
      gap: 6px;
      margin-bottom: 16px;
    }
    .window-dots span {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      transition: opacity 0.2s;
    }
    .window-dots .w-red    { background: #ff5f57; }
    .window-dots .w-yellow { background: #ffbd2e; }
    .window-dots .w-green  { background: #28c840; }

    .window-dots span:hover { opacity: 0.7; }

    /* ─── SECTION NUMBER ─── */
    .section-number {
      font-size: 42px;
      font-weight: 800;
      font-family: var(--sans);
      line-height: 1;
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      opacity: 0.2;
      position: absolute;
      top: -6px;
      right: 24px;
      user-select: none;
      pointer-events: none;
    }

    /* ─── HERO ─── */
    .hero {
      border: 1px solid var(--border);
      background: var(--surface);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      padding: 48px 48px 40px;
      margin-bottom: 4px;
      position: relative;
      overflow: hidden;
      transition: border-color 0.4s, box-shadow 0.4s;
    }
    .hero:hover {
      border-color: var(--border-glow);
      box-shadow: 0 0 30px rgba(0, 229, 160, 0.04), inset 0 0 30px rgba(0, 229, 160, 0.02);
    }

    .hero .accent-bar {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2), transparent);
    }

    .hero-top {
      display: flex;
      align-items: flex-start;
      gap: 32px;
      flex-wrap: wrap;
    }

    .avatar {
      width: 100px;
      height: 100px;
      border-radius: 6px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 38px;
      font-family: var(--sans);
      font-weight: 800;
      letter-spacing: -2px;
      position: relative;
      background: var(--surface);
      z-index: 1;
    }
    .avatar::before {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: 8px;
      background: var(--accent-gradient);
      z-index: -1;
      animation: avatarSpin 4s linear infinite;
    }
    .avatar::after {
      content: '';
      position: absolute;
      inset: 2px;
      border-radius: 5px;
      background: var(--bg);
      z-index: -1;
    }
    .avatar span {
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      position: relative;
      z-index: 1;
    }

    @keyframes avatarSpin {
      0%   { filter: hue-rotate(0deg); }
      100% { filter: hue-rotate(360deg); }
    }

    .hero-info { flex: 1; min-width: 240px; }

    .prompt {
      color: var(--muted);
      font-size: 11px;
      margin-bottom: 6px;
      letter-spacing: 0.08em;
      min-height: 18px;
    }
    .prompt span { color: var(--accent); }

    .prompt .cursor {
      display: inline-block;
      width: 7px;
      height: 14px;
      background: var(--accent);
      margin-left: 2px;
      vertical-align: middle;
      animation: cursorBlink 0.7s step-end infinite;
    }
    .prompt .cursor.done {
      animation: cursorBlink 0.7s step-end 3 forwards;
    }

    @keyframes cursorBlink {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0; }
    }

    .name {
      font-family: var(--sans);
      font-size: clamp(36px, 7vw, 60px);
      font-weight: 800;
      line-height: 1;
      margin-bottom: 12px;
      letter-spacing: -1.5px;
      background: linear-gradient(135deg, #eaf4f8 0%, #c8d8de 40%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .title-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 229, 160, 0.06);
      border: 1px solid rgba(0, 229, 160, 0.2);
      color: var(--accent);
      font-size: 12px;
      padding: 5px 14px;
      border-radius: 3px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      box-shadow: 0 0 20px rgba(0, 229, 160, 0.06);
    }
    .title-badge:hover {
      box-shadow: 0 0 30px rgba(0, 229, 160, 0.15);
      border-color: rgba(0, 229, 160, 0.4);
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: blink 1.2s infinite;
      box-shadow: 0 0 6px var(--accent);
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0; }
    }

    .contact-row {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
      position: relative;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text);
      text-decoration: none;
      font-size: 12px;
      transition: color 0.3s, transform 0.3s, text-shadow 0.3s;
    }
    .contact-item:hover {
      color: var(--accent);
      transform: translateY(-2px);
      text-shadow: 0 0 16px rgba(0, 229, 160, 0.35);
    }
    .contact-item svg {
      opacity: 0.5;
      flex-shrink: 0;
      transition: opacity 0.3s, filter 0.3s;
    }
    .contact-item:hover svg {
      opacity: 1;
      filter: drop-shadow(0 0 5px rgba(0, 229, 160, 0.5));
    }

    /* ─── PROFILE ─── */
    .profile-block {
      background: var(--surface);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      border-top: none;
      padding: 28px 48px;
      margin-bottom: 4px;
      position: relative;
      transition: border-color 0.4s;
    }
    .profile-block:hover {
      border-color: var(--border-glow);
    }

    .profile-block p {
      color: var(--text);
      font-size: 13px;
      line-height: 1.8;
    }
    .profile-block p strong { color: var(--accent); font-weight: 500; }

    /* ─── GRID SECTIONS ─── */
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px;
      margin-bottom: 4px;
    }
    @media (max-width: 640px) { .grid-2 { grid-template-columns: 1fr; } }

    /* ─── SECTION ─── */
    .section {
      background: var(--surface);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      padding: 32px;
      position: relative;
      transition: border-color 0.4s, box-shadow 0.4s, background 0.4s;
    }
    .section:hover {
      border-color: var(--border-glow);
      background: var(--surface-hover);
      box-shadow: 0 0 30px rgba(0, 229, 160, 0.03), inset 0 0 30px rgba(0, 229, 160, 0.01);
    }

    .section-label {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--border), transparent);
    }

    /* ─── EXPERIENCE ─── */
    .exp-list { display: flex; flex-direction: column; gap: 32px; }

    .exp-item {
      position: relative;
      padding-left: 24px;
    }

    .exp-item .exp-dot {
      position: absolute;
      left: -1px; top: 7px;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--bg);
      border: 2px solid var(--accent);
      box-shadow: 0 0 12px rgba(0, 229, 160, 0.3), 0 0 0 3px rgba(0, 229, 160, 0.06);
      z-index: 1;
      transition: box-shadow 0.3s, transform 0.3s;
    }
    .exp-item:hover .exp-dot {
      box-shadow: 0 0 20px rgba(0, 229, 160, 0.5), 0 0 0 4px rgba(0, 229, 160, 0.1);
      transform: scale(1.15);
    }

    .exp-item .exp-line {
      content: '';
      position: absolute;
      left: 3px; top: 18px;
      width: 2px;
      bottom: -32px;
      background: linear-gradient(var(--border), transparent);
    }
    .exp-item:last-child .exp-line { display: none; }

    .exp-item .exp-line-fill {
      content: '';
      position: absolute;
      left: 3px; top: 18px;
      width: 2px;
      bottom: -32px;
      background: linear-gradient(var(--accent), var(--accent2), transparent);
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 1.2s ease;
    }
    .exp-item:last-child .exp-line-fill { display: none; }
    .exp-item.draw .exp-line-fill {
      transform: scaleY(1);
    }

    .exp-header { margin-bottom: 4px; }

    .exp-role {
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 600;
      color: var(--bright);
    }

    .exp-company {
      font-size: 11px;
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .exp-date {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .exp-bullets { list-style: none; display: flex; flex-direction: column; gap: 5px; }

    .exp-bullets li {
      font-size: 12px;
      color: var(--text);
      padding-left: 16px;
      position: relative;
      line-height: 1.6;
    }
    .exp-bullets li::before {
      content: '›';
      position: absolute;
      left: 0;
      color: var(--accent);
      font-weight: bold;
      font-size: 14px;
    }

    /* ─── SKILLS ─── */
    .skill-group { margin-bottom: 18px; }
    .skill-group:last-child { margin-bottom: 0; }

    .skill-cat {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .skill-tags { display: flex; flex-wrap: wrap; gap: 6px; }

    .tag {
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 3px;
      border: 1px solid var(--border);
      color: var(--text);
      background: rgba(255, 255, 255, 0.015);
      transition: all 0.3s;
    }
    .tag:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(0, 229, 160, 0.06);
      box-shadow: 0 0 16px rgba(0, 229, 160, 0.12);
      transform: translateY(-2px);
    }

    .tag.accent {
      border-color: rgba(0, 229, 160, 0.3);
      color: var(--accent);
      background: rgba(0, 229, 160, 0.05);
    }
    .tag.accent:hover {
      box-shadow: 0 0 20px rgba(0, 229, 160, 0.2);
    }

    .tag.blue {
      border-color: rgba(0, 153, 255, 0.3);
      color: var(--accent2);
      background: rgba(0, 153, 255, 0.05);
    }
    .tag.blue:hover {
      border-color: var(--accent2);
      box-shadow: 0 0 20px rgba(0, 153, 255, 0.2);
    }

    /* stagger tags */
    .tag-stagger {
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .skill-tags.visible .tag-stagger {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── EDU ─── */
    .edu-item {
      padding-left: 24px;
      position: relative;
    }
    .edu-item::before {
      content: '';
      position: absolute;
      left: 0; top: 7px;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--bg);
      border: 2px solid var(--accent2);
      box-shadow: 0 0 12px rgba(0, 153, 255, 0.25), 0 0 0 3px rgba(0, 153, 255, 0.05);
    }

    .edu-degree { font-family: var(--sans); font-size: 14px; font-weight: 600; color: var(--bright); }
    .edu-school { font-size: 11px; background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: 0.05em; text-transform: uppercase; }
    .edu-date   { font-size: 11px; color: var(--muted); }

    /* ─── LANGUAGES ─── */
    .lang-list { display: flex; flex-direction: column; gap: 14px; }

    .lang-name { font-size: 13px; color: var(--bright); margin-bottom: 3px; }
    .lang-level { font-size: 11px; color: var(--muted); }

    .lang-bar {
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      margin-top: 5px;
      overflow: hidden;
      position: relative;
    }
    .lang-bar::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 2px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03));
    }
    .lang-fill {
      height: 100%;
      width: 0;
      border-radius: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
    }
    .lang-fill::after {
      content: '';
      position: absolute;
      right: 0; top: 0;
      width: 8px; height: 100%;
      border-radius: 2px;
      background: var(--accent);
      filter: blur(4px);
      opacity: 0.6;
    }

    /* ─── SOFT SKILLS ─── */
    .soft-grid { display: flex; flex-direction: column; gap: 8px; }

    .soft-item {
      font-size: 12px;
      color: var(--text);
      padding: 8px 14px;
      border: 1px solid var(--border);
      border-left: 2px solid var(--accent);
      background: rgba(0, 229, 160, 0.015);
      transition: border-color 0.3s, background 0.3s, transform 0.3s, box-shadow 0.3s;
    }
    .soft-item:hover {
      border-color: var(--accent);
      background: rgba(0, 229, 160, 0.05);
      transform: translateX(4px);
      box-shadow: 0 0 12px rgba(0, 229, 160, 0.06);
    }

    /* ─── STATUS BAR ─── */
    .status-bar {
      margin-top: 48px;
      padding: 10px 16px;
      border: 1px solid var(--border);
      background: var(--surface);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.04em;
      transition: border-color 0.4s;
    }
    .status-bar:hover {
      border-color: var(--border-glow);
    }
    .status-bar .sb-left { display: flex; align-items: center; gap: 12px; }
    .status-bar .sb-right { display: flex; align-items: center; gap: 12px; }

    .sb-indicator {
      display: inline-block;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
      animation: blink 2s infinite;
      margin-right: 4px;
    }
    .sb-key {
      color: var(--accent2);
    }

    /* ─── FOOTER ─── */
    .footer {
      text-align: center;
      margin-top: 24px;
      font-size: 11px;
      color: var(--muted);
    }
    .footer span { background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 640px) {
      .hero { padding: 28px 20px; }
      .profile-block { padding: 20px; }
      .section { padding: 24px 20px; }
      .wrapper { padding: 32px 16px 60px; }
      .section-number { font-size: 32px; right: 16px; }
      .status-bar { flex-direction: column; gap: 6px; text-align: center; }
    }
    @media (max-width: 480px) {
      .hero-top { flex-direction: column; align-items: center; text-align: center; }
      .contact-row { justify-content: center; }
      .name { font-size: 28px; }
    }
  </style>
</head>
<body>
  <!-- Spotlight -->
  <div id="spotlight"></div>
  <!-- Particles -->
  <div id="particles"></div>

  <div class="wrapper">
    <slot />
  </div>

  <script>
    // ─── SPOTLIGHT ───
    (function() {
      const spot = /** @type {HTMLElement} */ (document.getElementById('spotlight'));
      if (!spot) return;
      /** @type {number | null} */
      let rafId = null;
      let mx = window.innerWidth / 2, my = window.innerHeight / 2;

      document.addEventListener('mousemove', (e) => {
        mx = e.clientX;
        my = e.clientY;
        if (!rafId) {
          rafId = window.requestAnimationFrame(() => {
            spot.style.left = mx + 'px';
            spot.style.top = my + 'px';
            rafId = null;
          });
        }
      });
    })();

    // ─── PARTICLES ───
    (function() {
      const container = document.getElementById('particles');
      if (!container) return;
      const count = 15;
      for (let i = 0; i < count; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        p.style.left = Math.random() * 100 + '%';
        p.style.width = (1.5 + Math.random() * 2.5) + 'px';
        p.style.height = p.style.width;
        p.style.animationDuration = (15 + Math.random() * 25) + 's';
        p.style.animationDelay = (Math.random() * 20) + 's';
        const colors = ['var(--accent)', 'var(--accent2)', 'var(--muted)'];
        p.style.background = colors[Math.floor(Math.random() * colors.length)];
        container.appendChild(p);
      }
    })();

    // ─── SCROLL REVEAL ───
    (function() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');

            const parentItem = entry.target.closest('.exp-item');
            if (parentItem) {
              parentItem.classList.add('draw');
            }

            const langFill = entry.target.querySelector('.lang-fill');
            if (langFill) {
              const w = langFill.getAttribute('data-width');
              if (w) setTimeout(() => { langFill.style.width = w; }, 200);
            }

            const skillTags = entry.target.closest('.skill-tags');
            if (skillTags) {
              skillTags.classList.add('visible');
            }

            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    })();

    // ─── TYPEWRITER ───
    (function() {
      const promptEl = document.getElementById('typewriter-prompt');
      if (!promptEl) return;
      const text = promptEl.getAttribute('data-text') || '';
      const cursor = promptEl.querySelector('.cursor');
      let i = 0;

      function type() {
        if (i < text.length) {
          promptEl.textContent = text.slice(0, i + 1);
          promptEl.appendChild(cursor);
          i++;
          setTimeout(type, 50 + Math.random() * 30);
        } else {
          cursor.classList.add('done');
          setTimeout(() => { cursor.style.display = 'none'; }, 2100);
        }
      }
      setTimeout(type, 400);
    })();
  </script>
</body>
</html>
