---
// Layout component — shell HTML + CSS global + animaciones + scroll reveal
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Alexander Pardo — Desarrollador de Software</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet"/>

  <style is:global>
    /* ═══════════════════════════════════════════
       CSS GLOBAL — migrado desde cv-preuba.html
       ═══════════════════════════════════════════ */

    :root {
      --bg:       #0a0e0f;
      --surface:  #111618;
      --border:   #1e2a2e;
      --accent:   #00e5a0;
      --accent2:  #0099ff;
      --muted:    #4a6270;
      --text:     #c8d8de;
      --bright:   #eaf4f8;
      --mono:     'JetBrains Mono', monospace;
      --sans:     'Syne', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      font-size: 14px;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ─── NOISE OVERLAY ─── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.4;
    }

    /* ─── GRID LINES ─── */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
      opacity: 0.3;
    }

    /* ─── PARTICLES CONTAINER ─── */
    #particles {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .particle {
      position: absolute;
      width: 3px;
      height: 3px;
      background: var(--accent);
      border-radius: 50%;
      opacity: 0;
      animation: floatParticle linear infinite;
    }

    @keyframes floatParticle {
      0%   { transform: translateY(100vh) scale(0); opacity: 0; }
      10%  { opacity: 0.25; }
      90%  { opacity: 0.15; }
      100% { transform: translateY(-10vh) scale(1); opacity: 0; }
    }

    /* ─── LAYOUT ─── */
    .wrapper {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 60px 32px 100px;
    }

    /* ─── SCROLL REVEAL ─── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }

    /* ─── HERO ─── */
    .hero {
      border: 1px solid var(--border);
      background: var(--surface);
      padding: 48px 48px 40px;
      margin-bottom: 4px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2), transparent);
    }

    .hero-top {
      display: flex;
      align-items: flex-start;
      gap: 32px;
      flex-wrap: wrap;
    }

    .avatar {
      width: 96px;
      height: 96px;
      border-radius: 4px;
      border: 2px solid var(--accent);
      background: var(--border);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      color: var(--accent);
      font-family: var(--sans);
      font-weight: 800;
      letter-spacing: -2px;
      box-shadow: 0 0 20px rgba(0, 229, 160, 0.15);
      animation: avatarGlow 3s ease-in-out infinite;
    }

    @keyframes avatarGlow {
      0%, 100% { box-shadow: 0 0 20px rgba(0, 229, 160, 0.15); }
      50%      { box-shadow: 0 0 35px rgba(0, 229, 160, 0.3); }
    }

    .hero-info { flex: 1; min-width: 240px; }

    .prompt {
      color: var(--muted);
      font-size: 11px;
      margin-bottom: 6px;
      letter-spacing: 0.08em;
      min-height: 18px;
    }
    .prompt span { color: var(--accent); }

    .prompt .cursor {
      display: inline-block;
      width: 7px;
      height: 14px;
      background: var(--accent);
      margin-left: 2px;
      vertical-align: middle;
      animation: cursorBlink 0.7s step-end infinite;
    }
    .prompt .cursor.done {
      animation: cursorBlink 0.7s step-end 3 forwards;
    }

    @keyframes cursorBlink {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0; }
    }

    .name {
      font-family: var(--sans);
      font-size: clamp(32px, 6vw, 52px);
      font-weight: 800;
      color: var(--bright);
      line-height: 1;
      margin-bottom: 10px;
      letter-spacing: -1px;
    }

    .title-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(0, 229, 160, 0.08);
      border: 1px solid rgba(0, 229, 160, 0.25);
      color: var(--accent);
      font-size: 12px;
      padding: 4px 12px;
      border-radius: 2px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      animation: badgeGlow 2s ease-in-out infinite;
    }

    @keyframes badgeGlow {
      0%, 100% { box-shadow: 0 0 5px rgba(0, 229, 160, 0.1); }
      50%      { box-shadow: 0 0 15px rgba(0, 229, 160, 0.25); }
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: blink 1.2s infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0; }
    }

    .contact-row {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text);
      text-decoration: none;
      font-size: 12px;
      transition: color 0.3s, transform 0.3s, text-shadow 0.3s;
    }
    .contact-item:hover {
      color: var(--accent);
      transform: translateY(-1px);
      text-shadow: 0 0 12px rgba(0, 229, 160, 0.3);
    }
    .contact-item svg {
      opacity: 0.5;
      flex-shrink: 0;
      transition: opacity 0.3s, filter 0.3s;
    }
    .contact-item:hover svg {
      opacity: 1;
      filter: drop-shadow(0 0 4px rgba(0, 229, 160, 0.4));
    }

    /* ─── PROFILE ─── */
    .profile-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-top: none;
      padding: 28px 48px;
      margin-bottom: 4px;
    }

    .profile-block p {
      color: var(--text);
      font-size: 13px;
      line-height: 1.8;
    }

    .profile-block p strong { color: var(--accent); font-weight: 500; }

    /* ─── GRID SECTIONS ─── */
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px;
      margin-bottom: 4px;
    }

    @media (max-width: 640px) { .grid-2 { grid-template-columns: 1fr; } }

    /* ─── SECTION ─── */
    .section {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 32px;
    }

    .section-label {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ─── EXPERIENCE ─── */
    .exp-list { display: flex; flex-direction: column; gap: 28px; }

    .exp-item {
      position: relative;
      padding-left: 20px;
    }

    .exp-item::before {
      content: '';
      position: absolute;
      left: 0; top: 7px;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
      transition: box-shadow 0.3s;
    }
    .exp-item:hover::before {
      box-shadow: 0 0 16px var(--accent), 0 0 30px rgba(0, 229, 160, 0.3);
    }

    .exp-item::after {
      content: '';
      position: absolute;
      left: 2px; top: 16px;
      width: 1px;
      bottom: -28px;
      background: linear-gradient(var(--border), transparent);
    }

    .exp-item:last-child::after { display: none; }

    .exp-item .exp-line {
      content: '';
      position: absolute;
      left: 2px; top: 16px;
      width: 1px;
      bottom: -28px;
      background: linear-gradient(var(--accent), transparent);
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 1s ease;
    }
    .exp-item:last-child .exp-line { display: none; }
    .exp-item.draw .exp-line {
      transform: scaleY(1);
    }

    .exp-header { margin-bottom: 4px; }

    .exp-role {
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 600;
      color: var(--bright);
    }

    .exp-company {
      font-size: 11px;
      color: var(--accent2);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .exp-date {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .exp-bullets { list-style: none; display: flex; flex-direction: column; gap: 5px; }

    .exp-bullets li {
      font-size: 12px;
      color: var(--text);
      padding-left: 14px;
      position: relative;
      line-height: 1.6;
    }

    .exp-bullets li::before {
      content: '›';
      position: absolute;
      left: 0;
      color: var(--accent);
      font-weight: bold;
    }

    /* ─── SKILLS ─── */
    .skill-group { margin-bottom: 18px; }
    .skill-group:last-child { margin-bottom: 0; }

    .skill-cat {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .skill-tags { display: flex; flex-wrap: wrap; gap: 6px; }

    .tag {
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 2px;
      border: 1px solid var(--border);
      color: var(--text);
      background: rgba(255,255,255,0.02);
      transition: all 0.3s;
    }

    .tag:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(0, 229, 160, 0.08);
      box-shadow: 0 0 12px rgba(0, 229, 160, 0.15);
      transform: translateY(-1px);
    }

    .tag.accent {
      border-color: rgba(0, 229, 160, 0.35);
      color: var(--accent);
      background: rgba(0, 229, 160, 0.07);
    }
    .tag.accent:hover {
      box-shadow: 0 0 15px rgba(0, 229, 160, 0.25);
    }

    .tag.blue {
      border-color: rgba(0, 153, 255, 0.35);
      color: var(--accent2);
      background: rgba(0, 153, 255, 0.07);
    }
    .tag.blue:hover {
      border-color: var(--accent2);
      box-shadow: 0 0 15px rgba(0, 153, 255, 0.25);
    }

    /* stagger tags */
    .tag-stagger {
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .skill-tags.visible .tag-stagger {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── EDU ─── */
    .edu-item { padding-left: 20px; position: relative; }
    .edu-item::before {
      content: '';
      position: absolute;
      left: 0; top: 7px;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent2);
      box-shadow: 0 0 8px var(--accent2);
    }

    .edu-degree { font-family: var(--sans); font-size: 14px; font-weight: 600; color: var(--bright); }
    .edu-school { font-size: 11px; color: var(--accent2); letter-spacing: 0.05em; text-transform: uppercase; }
    .edu-date   { font-size: 11px; color: var(--muted); }

    /* ─── LANGUAGES ─── */
    .lang-list { display: flex; flex-direction: column; gap: 12px; }

    .lang-name { font-size: 13px; color: var(--bright); margin-bottom: 4px; }
    .lang-level { font-size: 11px; color: var(--muted); }

    .lang-bar {
      height: 3px;
      background: var(--border);
      border-radius: 2px;
      margin-top: 5px;
      overflow: hidden;
    }
    .lang-fill {
      height: 100%;
      width: 0;
      border-radius: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      transition: width 1.2s ease;
    }
    .lang-fill.filled {
      /* width is set inline via JS */
    }

    /* ─── SOFT SKILLS ─── */
    .soft-grid { display: flex; flex-direction: column; gap: 8px; }

    .soft-item {
      font-size: 12px;
      color: var(--text);
      padding: 7px 12px;
      border: 1px solid var(--border);
      border-left: 2px solid var(--accent);
      background: rgba(0, 229, 160, 0.02);
      transition: border-color 0.3s, background 0.3s, transform 0.3s;
    }
    .soft-item:hover {
      border-color: var(--accent);
      background: rgba(0, 229, 160, 0.06);
      transform: translateX(4px);
    }

    /* ─── FOOTER ─── */
    .footer {
      text-align: center;
      margin-top: 40px;
      font-size: 11px;
      color: var(--muted);
    }
    .footer span { color: var(--accent); }

    /* ─── ANIMACIONES ORIGINALES ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── TYPEWRITER ─── */
    .typewriter-text {
      display: inline;
      overflow: hidden;
      white-space: nowrap;
      border-right: 2px solid transparent;
      animation: typewriter 1.8s steps(22) forwards;
    }

    @keyframes typewriter {
      from { width: 0; }
      to   { width: 100%; }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 640px) {
      .hero { padding: 28px 20px 28px; }
      .profile-block { padding: 20px 20px; }
      .section { padding: 24px 20px; }
      .wrapper { padding: 32px 16px 60px; }
    }
    @media (max-width: 480px) {
      .hero-top { flex-direction: column; align-items: center; text-align: center; }
      .contact-row { justify-content: center; }
      .name { font-size: 28px; }
    }
  </style>
</head>
<body>
  <!-- Particles container -->
  <div id="particles"></div>

  <div class="wrapper">
    <slot />
  </div>

  <script>
    // ─── PARTICLES ───
    (function() {
      const container = document.getElementById('particles');
      if (!container) return;
      const count = 20;
      for (let i = 0; i < count; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        p.style.left = Math.random() * 100 + '%';
        p.style.width = (1.5 + Math.random() * 2) + 'px';
        p.style.height = p.style.width;
        p.style.animationDuration = (12 + Math.random() * 20) + 's';
        p.style.animationDelay = (Math.random() * 20) + 's';
        const colors = ['var(--accent)', 'var(--accent2)', 'var(--muted)'];
        p.style.background = colors[Math.floor(Math.random() * colors.length)];
        container.appendChild(p);
      }
    })();

    // ─── SCROLL REVEAL ───
    (function() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');

            // Trigger timeline draw
            const parentItem = entry.target.closest('.exp-item');
            if (parentItem) {
              parentItem.classList.add('draw');
            }

            // Trigger language bars
            const langFill = entry.target.querySelector('.lang-fill');
            if (langFill) {
              const w = langFill.getAttribute('data-width');
              if (w) setTimeout(() => { langFill.style.width = w; }, 200);
            }

            // Trigger skill stagger
            const skillTags = entry.target.closest('.skill-tags');
            if (skillTags) {
              skillTags.classList.add('visible');
            }

            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    })();

    // ─── TYPEWRITER ───
    (function() {
      const promptEl = document.getElementById('typewriter-prompt');
      if (!promptEl) return;
      const text = promptEl.getAttribute('data-text') || '';
      const cursor = promptEl.querySelector('.cursor');
      let i = 0;

      function type() {
        if (i < text.length) {
          promptEl.textContent = text.slice(0, i + 1);
          // re-append cursor
          promptEl.appendChild(cursor);
          i++;
          setTimeout(type, 50 + Math.random() * 30);
        } else {
          cursor.classList.add('done');
          setTimeout(() => { cursor.style.display = 'none'; }, 2100);
        }
      }
      setTimeout(type, 400);
    })();
  </script>
</body>
</html>
